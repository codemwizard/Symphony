{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["active_version_id", "versions"],
  "properties": {
    "active_version_id": {"type": "string", "minLength": 1},
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version_id", "created_at", "created_by", "policies"],
        "properties": {
          "version_id": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "minLength": 1},
          "created_by": {"type": "string", "minLength": 1},
          "policies": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rail_id",
                "cadence_seconds",
                "retry_window_seconds",
                "max_attempts",
                "timeout_threshold_seconds",
                "orphan_threshold_seconds",
                "circuit_breaker_threshold_rate",
                "circuit_breaker_window_seconds"
              ],
              "properties": {
                "rail_id": {"type": "string", "minLength": 1},
                "cadence_seconds": {"type": "integer", "minimum": 1},
                "retry_window_seconds": {"type": "integer", "minimum": 1},
                "max_attempts": {"type": "integer", "minimum": 1},
                "timeout_threshold_seconds": {"type": "integer", "minimum": 1},
                "orphan_threshold_seconds": {"type": "integer", "minimum": 1},
                "circuit_breaker_threshold_rate": {"type": "number", "minimum": 0, "maximum": 1},
                "circuit_breaker_window_seconds": {"type": "integer", "minimum": 1}
              }
            }
          }
        }
      }
    }
  }
}
