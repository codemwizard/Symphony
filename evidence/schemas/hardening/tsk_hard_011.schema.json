{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "check_id",
    "task_id",
    "status",
    "pass",
    "policy_store_mode",
    "policy_version_id_present",
    "activation_event_emitted",
    "activation_unsigned_reason",
    "negative_missing_version_id_rejected",
    "negative_in_place_edit_blocked"
  ],
  "properties": {
    "check_id": {"type": "string", "const": "TSK-HARD-011"},
    "task_id": {"type": "string", "const": "TSK-HARD-011"},
    "status": {"type": "string", "enum": ["PASS", "FAIL"]},
    "pass": {"type": "boolean"},
    "policy_store_mode": {"type": "string", "enum": ["file-backed", "db-backed"]},
    "policy_version_id_present": {"type": "boolean", "const": true},
    "activation_event_emitted": {"type": "boolean", "const": true},
    "activation_unsigned_reason": {"type": "string", "enum": ["DEPENDENCY_NOT_READY"]},
    "negative_missing_version_id_rejected": {"type": "boolean", "const": true},
    "negative_in_place_edit_blocked": {"type": "boolean", "const": true}
  }
}
