{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "continuity_id", "window_start", "window_end", "verification_status", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "verification_continuity_event"},
    "continuity_id": {"type": "string", "minLength": 1},
    "window_start": {"type": "string", "minLength": 1},
    "window_end": {"type": "string", "minLength": 1},
    "verification_status": {"type": "string", "enum": ["PASS", "FAIL"]},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
