{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "quarantine_id", "adapter", "error_code", "raw_payload_hash", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "malformed_quarantine_event"},
    "quarantine_id": {"type": "string", "minLength": 1},
    "adapter": {"type": "string", "minLength": 1},
    "error_code": {"type": "string", "minLength": 1},
    "raw_payload_hash": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
