{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "adjustment_id", "approval_stage", "approver_role", "decision", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "adjustment_approval_event"},
    "adjustment_id": {"type": "string", "minLength": 1},
    "approval_stage": {"type": "string", "minLength": 1},
    "approver_role": {"type": "string", "minLength": 1},
    "decision": {"type": "string", "enum": ["APPROVE", "REJECT"]},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
