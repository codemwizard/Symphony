{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "inquiry_id", "instruction_id", "rail", "poll_count", "status", "timestamp_utc", "policy_version_id"],
  "properties": {
    "event_class": {"type": "string", "const": "inquiry_event"},
    "inquiry_id": {"type": "string", "minLength": 1},
    "instruction_id": {"type": "string", "minLength": 1},
    "rail": {"type": "string", "minLength": 1},
    "poll_count": {"type": "integer", "minimum": 0},
    "status": {"type": "string", "enum": ["INQUIRY_SENT", "INQUIRY_POLLED", "INQUIRY_EXHAUSTED", "RESOLVED"]},
    "policy_version_id": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
