{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "attestation_id", "subject_ref", "orphan_reason", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "orphaned_attestation_event"},
    "attestation_id": {"type": "string", "minLength": 1},
    "subject_ref": {"type": "string", "minLength": 1},
    "orphan_reason": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
