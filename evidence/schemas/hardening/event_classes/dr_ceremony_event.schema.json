{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "ceremony_id", "region", "checkpoint_hash", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "dr_ceremony_event"},
    "ceremony_id": {"type": "string", "minLength": 1},
    "region": {"type": "string", "minLength": 1},
    "checkpoint_hash": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
