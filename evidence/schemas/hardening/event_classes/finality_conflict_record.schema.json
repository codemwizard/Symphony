{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_class", "conflict_id", "instruction_id", "source_a", "source_b", "timestamp_utc"],
  "properties": {
    "event_class": {"type": "string", "const": "finality_conflict_record"},
    "conflict_id": {"type": "string", "minLength": 1},
    "instruction_id": {"type": "string", "minLength": 1},
    "source_a": {"type": "string", "minLength": 1},
    "source_b": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1}
  }
}
