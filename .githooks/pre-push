#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# Symphony pre-push hook - Layer 1: Git enforcement
# Blocks all direct pushes to main (local branch or remote ref)
# Blocks force pushes to any branch
# This is a mechanical hard block - not advisory.
# ============================================================

ROOT="$(git rev-parse --show-toplevel)"

# Block if currently ON main locally
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [[ "$CURRENT_BRANCH" == "main" ]]; then
  echo "❌ BLOCKED: You are on 'main'. Work must occur on feature branches." >&2
  echo "   Create a feature branch: git checkout -b feat/<name>" >&2
  exit 1
fi

# Block if pushing TO main (catches: push origin main, HEAD:main, feat:main)
# The '|| true' on the while condition handles empty stdin (no-op push).
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA || [[ -n "${REMOTE_REF:-}" ]]; do
  if [[ "${REMOTE_REF:-}" == "refs/heads/main" ]]; then
    echo "❌ BLOCKED: Direct push to 'main' is forbidden." >&2
    echo "   Attempted: $LOCAL_REF -> $REMOTE_REF" >&2
    echo "   Open a PR from your feature branch instead." >&2
    exit 1
  fi
done

# Block force pushes - agents use these to override failed verifiers
if [[ "${GIT_PUSH_OPTION_COUNT:-0}" -gt 0 ]]; then
  for ((i=0; i<GIT_PUSH_OPTION_COUNT; i++)); do
    opt="$(eval echo "\$GIT_PUSH_OPTION_$i")"
    if [[ "$opt" == "force" || "$opt" == "force-with-lease" ]]; then
      echo "❌ BLOCKED: Force push is not permitted in this repository." >&2
      exit 1
    fi
  done
fi

# Run pre-CI parity gate (original behaviour preserved)
bash "$ROOT/scripts/dev/pre_ci.sh"
