# .gitattributes
# TARGET: .gitattributes (repo root)
# Enforces LF line endings for all text files on commit.
# Prevents BOM and CRLF issues when files are authored on Windows.

* text=auto
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.json text eol=lf
*.py text eol=lf
*.toml text eol=lf
